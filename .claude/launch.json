{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "site",
      "runtimeExecutable": "node",
      "runtimeArgs": ["-e", "require('http').createServer((q,r)=>{const p='.'+require('url').parse(q.url).pathname;const f=p==='./'\u003f'./v1.html':p;require('fs').readFile(f,(e,d)=>{if(e){r.writeHead(404);r.end('Not found')}else{const m={'.html':'text/html','.webp':'image/webp','.css':'text/css','.js':'text/javascript'};r.writeHead(200,{'Content-Type':m[require('path').extname(f)]||'application/octet-stream'});r.end(d)}})}).listen(3000)"],
      "port": 3000
    }
  ]
}
